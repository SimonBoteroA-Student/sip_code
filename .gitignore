# General ignores
.DS_Store
.venv/
__pycache__/
*.pyc
.agent/workflows/

# Ignore all Data contents by default
Data/**

# Allow directories to be traversed so whitelists work
!Data/**/

# Whitelist code and documentation files in Data
!Data/**/*.py
!Data/**/*.ipynb
!Data/**/*.R
!Data/**/*.do
!Data/**/*.md
!Data/**/*.txt
!Data/**/*.yml
!Data/**/*.yaml
!Data/**/*.json
!Data/**/*.sql
!Data/**/*.sh
!Data/**/*.html

# Whitelist "Boletines" data
!Data/Propia/Boletines/**

# Ensure .DS_Store is still ignored even if folders are whitelisted
**/.DS_Store
